def total(values: list[int]) -> int:
    values_view = view values
    sum := 0

    for value in values_view:
        sum += value

    return sum

def pushValue(values: list[int], value: int):
    writable = borrow values
    writable.append(value)

def main():
    values := [1, 2, 3]
    print(total(values))

    pushValue(values, 4)
    print(total(values))
