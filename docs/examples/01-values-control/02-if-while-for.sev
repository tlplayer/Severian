def main():
    while count < 3 with count := 0:
        print(count)
        count += 1

    for value in range(0, 4):
        if value % 2 == 0:
            print("even")
        else:
            print("odd")

test with integration "control flow output":
    main()
    assert("0" in stdout)
    assert("1" in stdout)
    assert("2" in stdout)
    assert("even" in stdout)
    assert("odd" in stdout)
