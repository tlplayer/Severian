def add(a: int, b: int) -> int:
    return a + b

test:
    assert(add(1, 2) == 3)
    assert(add(20, 22) == 42)

def main():
    x = 10
    y = 32
    total = add(x, y)

    if total > 40:
        print("large")
    else:
        print("small")

test with integration "function output":
    main()
    assert("large" in stdout)
