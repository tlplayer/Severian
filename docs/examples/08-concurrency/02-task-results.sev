def fetch(url: string) -> Result[string, IOError]:
    body ?= http.get(url)
    return body

test:
    task = async fetch("https://example.test") with self
    result = await task

    switch result:
        ok body:
            assert(body != "")

        failure error:
            assert(false, error)

def main() -> Result[string, IOError]:
    return async fetch("https://example.test") with self
