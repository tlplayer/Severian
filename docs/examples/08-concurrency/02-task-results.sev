def fetch(url: string) -> Result[string, IOError]:
    body ?= http.get(url)
    return ok(body)

test:
    task = async fetch("https://example.test")
    result = await task

    switch result:
        ok body:
            assert(body != "")

        failure error:
            assert(false, error)

def main():
    task = async fetch("https://example.test")
    result = await task

    switch result:
        ok body:
            print(body)

        failure error:
            print(error)
