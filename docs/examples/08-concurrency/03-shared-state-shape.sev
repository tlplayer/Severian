class Counter:
    value: int

    def inc(self):
        value += 1

def count_all(list[int] values) -> int:
    counter := Counter(0)

    for value in values:
        if value > 0:
            counter.inc()

    return counter.value

def main():
    task = async count_all([1, -2, 3]) with self
    print(await task)
