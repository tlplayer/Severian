def lower_bound(values: list[int], target: int) -> int:
    low := 0
    high := size(values)

    while low < high:
        middle = low + (high - low) // 2
        if values[middle] < target:
            low = middle + 1
        else:
            high = middle

    return low

def main():
    values = [10, 20, 30]
    for i in indices(values):
        print(values[i])

    assert(lower_bound(values, 20) == 1)
    assert(lower_bound(values, 25) == 2)
