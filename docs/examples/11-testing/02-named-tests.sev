def clamp(value: int, low: int, high: int) -> int:
    if value < low:
        return low

    if value > high:
        return high

    return value

test "below range":
    assert(clamp(-1, 0, 10) == 0)

test "above range":
    assert(clamp(12, 0, 10) == 10)

test "inside range":
    assert(clamp(4, 0, 10) == 4)
