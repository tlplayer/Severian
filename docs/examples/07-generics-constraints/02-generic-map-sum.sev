trait Number:
    zero() -> Self
    add(other: Self) -> Self

def sumValues[key: Hash + Equal, value: Number](values: map[key, value]) -> value:
    total := value.zero()

    for _, value in values:
        total = total.add(value)

    return total

def main():
    counts = {"first": 34, "second": 8}
    print(sumValues(counts))
