trait Ordered:
    less_than(other: Self) -> bool

def largest[T: Ordered](values: list[T]) -> Option[T]:
    if values.len() == 0:
        return None

    best := values[0]

    for value in values:
        if best.less_than(value):
            best = value

    return Some(best)

def main():
    result = largest([3, 9, 2])
    print(result)
