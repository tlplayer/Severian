def read() -> Result[list[int], IOError] | None:
    # A real implementation reaches a system-call chaos point here.
    return [65, 66, 67]

test with chaos "read results":
    chaos.add(when read return None)
    chaos.add(when read return Failure(PermissionDenied))
    events_seen := 0

    for event in chaos:
        events_seen += 1
        result = read()
        # Validate the returned result under this event.

    assert(events_seen == 2)

test with chaos "read exceptions":
    chaos.add(when read throw PermissionDenied)
    chaos.add(when read throw TimedOut)
    events_seen := 0

    for event in chaos:
        events_seen += 1
        result = read()
        # Validate local handling or deliberate propagation.

    assert(events_seen == 2)

def wrapper() -> Result[int, IOError | BoundsError]:
    buffer ?= read()
    return buffer[0]

test with chaos "wrapper inherits read failures":
    # The runner discovers all four events through wrapper -> read.
    events_seen := 0

    for event in chaos:
        events_seen += 1
        result = wrapper()
        # Validate wrapper's handling or deliberate propagation for each event.

    assert(events_seen == 4)
