{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?!#).*(:|\\{)\\s*(#.*)?$",
    "decreaseIndentPattern": "^\\s*(else\\b.*:|\\})\\s*(#.*)?$"
  },
  "folding": {
    "offSide": true
  },
  "wordPattern": "(-?\\d+(?:\\.\\d+)?)|([^`~!@#$%^&*()=+[\\]{}\\\\|;:'\",.<>/?\\s]+)"
}
